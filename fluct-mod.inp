* MODES DU CANAL
*

bomlev -5
faster on


! Read topology and parameter files
stream ./toppar-charmm.str

open read card unit 15 name ./step1_pdbreader.psf
read psf card unit 15
close unit 15

open read card unit 16 name ./min_restr.crd
read coor card unit 16
close unit 16

!--------------------------------------------------------------!
!Energy Model
!Force field definition
nbond rdie eps 1.0 switch ctonnb 5.0 ctofnb 9.0 cutnb 10.0
!--------------------------------------------------------------!

skip CMAP

! Ouvrir fichier pour contenir les modes
open read file unit 41 name ./modes.mod

set i 6
label loop
incr i by 1

! Calculer les modes: 3N = 3* =  modes pour N= atomes
! On va calculer ici seulement 200 modes
! adicionado de dwin pard 400

vibran nmodes 100
! Ecrire le fichier des modes (valeurs et vecteurs propres des
! 20 premiers modes de plus basse frequence)
read norm file unit 41 mode @i thru @i

! Calcul des fluctuations (total de 7 a 200)
fluct atom temp 300 tfreq 0.1 mode 1 thru 1

end

scalar xcomp store 1
scalar ycomp +store 1
scalar zcomp +store 1
scalar wcomp recall 1
scalar wcomp sqrt
scalar wmain = wcomp

open write  card unit 42 name ./flut-@i.pdb
write coor pdb unit  42
!SCALar WCOMP SHOW SELE TYPE CA END
!SCALar WCOMP SHOW SELE TYPE SG END
rewind unit 41

if i .lt. 100  goto loop

stop
